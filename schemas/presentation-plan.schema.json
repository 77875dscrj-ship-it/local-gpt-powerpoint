{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local GPT PresentationPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "assistantMessage", "intent", "steps", "outline", "legacyActions", "warnings", "requiresApproval"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["2.0"]
    },
    "kind": {
      "type": "string",
      "enum": ["edit_plan", "review"]
    },
    "assistantMessage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "audience", "preserve"],
      "properties": {
        "goal": { "type": "string" },
        "audience": { "type": "string" },
        "preserve": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 20
        }
      }
    },
    "steps": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "detail"],
        "properties": {
          "title": { "type": "string", "maxLength": 120 },
          "detail": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "outline": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "changeId",
          "operation",
          "slideRef",
          "title",
          "keyMessage",
          "visualRole",
          "changes",
          "rationale",
          "sourceRefs",
          "risk",
          "selected"
        ],
        "properties": {
          "changeId": {
            "type": "string",
            "pattern": "^chg-[A-Za-z0-9_-]+$",
            "maxLength": 60
          },
          "operation": {
            "type": "string",
            "enum": ["create", "insert", "revise", "format", "review"]
          },
          "slideRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slideId", "slideIndex", "tempSlideKey"],
            "properties": {
              "slideId": { "type": ["integer", "null"] },
              "slideIndex": { "type": ["integer", "null"] },
              "tempSlideKey": { "type": ["string", "null"], "maxLength": 80 }
            }
          },
          "title": { "type": "string", "maxLength": 180 },
          "keyMessage": { "type": "string", "maxLength": 500 },
          "visualRole": { "type": "string", "maxLength": 80 },
          "changes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "summary"],
              "properties": {
                "type": { "type": "string", "maxLength": 80 },
                "summary": { "type": "string", "maxLength": 500 }
              }
            }
          },
          "rationale": { "type": "string", "maxLength": 900 },
          "sourceRefs": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sourceId", "locator"],
              "properties": {
                "sourceId": { "type": "string", "maxLength": 120 },
                "locator": { "type": "string", "maxLength": 240 }
              }
            }
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "selected": { "type": "boolean" }
        }
      }
    },
    "legacyActions": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "changeId",
          "type",
          "slide",
          "after",
          "text",
          "find",
          "replace",
          "fontSize",
          "width",
          "height",
          "left",
          "top",
          "autofit",
          "lineSpacing",
          "spaceBefore",
          "spaceAfter",
          "bold",
          "fillRgb",
          "title",
          "message",
          "notes",
          "columns",
          "rows",
          "items",
          "slides"
        ],
        "properties": {
          "changeId": {
            "type": "string",
            "pattern": "^chg-[A-Za-z0-9_-]+$",
            "maxLength": 60
          },
          "type": {
            "type": "string",
            "enum": [
              "replace_deck",
              "add_slides",
              "set_title",
              "set_body",
              "set_notes",
              "replace_text",
              "format_selection",
              "add_table_slide",
              "add_bar_chart_slide"
            ]
          },
          "slide": { "type": ["integer", "null"] },
          "after": { "type": ["integer", "null"] },
          "text": { "type": ["string", "null"] },
          "find": { "type": ["string", "null"] },
          "replace": { "type": ["string", "null"] },
          "fontSize": { "type": ["number", "null"] },
          "width": { "type": ["number", "null"] },
          "height": { "type": ["number", "null"] },
          "left": { "type": ["number", "null"] },
          "top": { "type": ["number", "null"] },
          "autofit": { "type": ["boolean", "null"] },
          "lineSpacing": { "type": ["number", "null"] },
          "spaceBefore": { "type": ["number", "null"] },
          "spaceAfter": { "type": ["number", "null"] },
          "bold": { "type": ["boolean", "null"] },
          "fillRgb": { "type": ["integer", "null"] },
          "title": { "type": ["string", "null"] },
          "message": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "columns": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 12
          },
          "rows": {
            "type": "array",
            "maxItems": 40,
            "items": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 12
            }
          },
          "items": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "value"],
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "number" }
              }
            }
          },
          "slides": {
            "type": "array",
            "maxItems": 40,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "title", "subtitle", "body", "bullets", "notes"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["title", "section", "content", "comparison"]
                },
                "title": { "type": "string" },
                "subtitle": { "type": "string" },
                "body": { "type": "string" },
                "bullets": {
                  "type": "array",
                  "items": { "type": "string" },
                  "maxItems": 12
                },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 500 }
    },
    "requiresApproval": { "type": "boolean" }
  }
}
